# =============================================================================
# Pegasus Ads — .env.example
# =============================================================================
# Copiar para .env e preencher. O arquivo .env NÃO vai para o Git (gitignored).
# Nota crítica: no VPS, .env NÃO pode ter aspas nos valores (Docker env-file
# não remove aspas).
# =============================================================================

# -----------------------------------------------------------------------------
# Database — Pegasus Ads (Supabase self-hosted, cluster alpes-ads_supabase)
# -----------------------------------------------------------------------------
# App client — RLS enforced (role pegasus_ads_app).
# Via pooler (PgBouncer/Supavisor) se disponível; caso contrário, conexão direta
# com o container alpes-ads_supabase-db:5432.
# Dentro da network alpes-ads_supabase_default usar sslmode=disable.
DATABASE_URL=postgres://pegasus_ads_app:CHANGE_ME@alpes-ads_supabase-db:5432/pegasus_ads?sslmode=disable

# Admin client — BYPASSRLS (role pegasus_ads_admin).
# Usado para crons, migrations, seeds e operações cross-workspace.
# Também usado por `drizzle-kit` (conexão direta, NÃO pooler).
DATABASE_URL_ADMIN=postgres://pegasus_ads_admin:CHANGE_ME@alpes-ads_supabase-db:5432/pegasus_ads?sslmode=disable

# -----------------------------------------------------------------------------
# Supabase Auth (compartilhado com CRM) — Fase 2
# -----------------------------------------------------------------------------
# URL pública do Supabase Studio / API gateway
NEXT_PUBLIC_SUPABASE_URL=https://alpes-ads-supabase.jz0ydc.easypanel.host
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME

# -----------------------------------------------------------------------------
# Legacy — Neon (descontinuar após Fase 1)
# -----------------------------------------------------------------------------
# Mantido temporariamente para rollback da Fase 1. Remover na Fase 5 (cleanup).
# DATABASE_URL_NEON=postgresql://neondb_owner:***@ep-small-wildflower-ac7jqlwl-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# Meta Ads
# -----------------------------------------------------------------------------
META_SYSTEM_USER_TOKEN=CHANGE_ME

# -----------------------------------------------------------------------------
# Google OAuth (login + Drive)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
REDIRECT_URI=https://pegasus.alpesd.com.br/api/auth/google/callback

# -----------------------------------------------------------------------------
# Gemini (IA)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=CHANGE_ME

# -----------------------------------------------------------------------------
# Workspace encryption (AES-256-GCM para tokens Meta at rest)
# -----------------------------------------------------------------------------
WORKSPACE_ENCRYPTION_KEY=CHANGE_ME

# -----------------------------------------------------------------------------
# Storage — Fase 5 (Vercel Blob → Supabase Storage)
# -----------------------------------------------------------------------------
# Legacy (remover na Fase 5)
BLOB_READ_WRITE_TOKEN=CHANGE_ME
# Novo (Supabase Storage, mesmo cluster)
# SUPABASE_STORAGE_BUCKET=pegasus-ads-images
