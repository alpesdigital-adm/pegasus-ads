{
  "title": "Pegasus Ads — Overview",
  "uid": "pegasus-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "America/Sao_Paulo",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["pegasus", "http"],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requests / min (por status)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "reqpm", "custom": { "fillOpacity": 10, "lineWidth": 1 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(http_requests_total[1m])) * 60",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latência HTTP (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 5, "lineWidth": 1 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "refId": "p50",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "p95",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "p99",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Erros 5xx / min (por rota)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqpm", "custom": { "fillOpacity": 10, "lineWidth": 1 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (route) (rate(http_requests_total{status=~\"5..\"}[1m])) * 60",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Memória residente + event loop lag",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 5, "lineWidth": 1 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "memory (MB)" },
            "properties": [{ "id": "unit", "value": "decmbytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "event loop lag (s)" },
            "properties": [{ "id": "unit", "value": "s" }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "refId": "mem",
          "expr": "pegasus_process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "memory (MB)"
        },
        {
          "refId": "lag",
          "expr": "pegasus_nodejs_eventloop_lag_seconds",
          "legendFormat": "event loop lag (s)"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Requests / min (último 1m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 600 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total[1m])) * 60"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Erros 5xx (última 1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_requests_total{status=~\"5..\"}[1h]))"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "p95 HTTP (última 5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))"
        }
      ]
    }
  ]
}
